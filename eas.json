{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_BASE_URL": "http://192.168.196.47:3000/api",
        "EXPO_PUBLIC_WS_URL": "ws://192.168.196.47:3000",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "1",
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_BASE_URL": "https://alphaai-app.duckdns.org/api",
        "EXPO_PUBLIC_WS_URL": "wss://alphaai-app.duckdns.org",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "1",
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://alphaai-app.duckdns.org/api",
        "EXPO_PUBLIC_WS_URL": "wss://alphaai-app.duckdns.org",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "1",
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "your-apple-id@email.com",
        "ascAppId": "your-asc-app-id"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services.json",
        "track": "internal"
      }
    }
  }
}
