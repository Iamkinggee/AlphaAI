# ═══════════════════════════════════════════════════════════════
# AlphaAI Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── Binance ───────────────────────────────────────────────────
# No API key needed for public market data (WebSocket + REST)
# Only needed if implementing authenticated endpoints (futures positions)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── OpenAI (GPT-4o for AI Trading Analyst) ───────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Firebase Cloud Messaging (Push Notifications) ────────────
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# ─── Expo Push Notifications ──────────────────────────────────
EXPO_ACCESS_TOKEN=your-expo-access-token

# ─── JWT Authentication ───────────────────────────────────────
JWT_SECRET=your-jwt-secret-at-least-32-characters
JWT_REFRESH_SECRET=your-refresh-jwt-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── CoinGecko API ────────────────────────────────────────────
COINGECKO_API_KEY=your-coingecko-api-key

# ─── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Mobile App Runtime Endpoints (APK / production) ───────────
# Set these in EAS project environment variables for production builds.
EXPO_PUBLIC_API_BASE_URL=https://api.alphaai.app/api
EXPO_PUBLIC_WS_URL=wss://api.alphaai.app

# ─── Signal Engine ─────────────────────────────────────────────
# Pairs are auto-discovered from top 80 by 30-day volume
# Override with comma-separated list to monitor specific pairs
MONITORED_PAIRS_OVERRIDE=
# Minimum confluence score for push notifications (0-100)
MIN_PUSH_SCORE=65
