# AlphaAI Backend — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Server ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Supabase (required for production) ───────────────────────────────
# Get from: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Redis (required for production) ──────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://:<password>@<host>:6380
REDIS_URL=redis://localhost:6379

# ── Binance API (optional — public endpoints work without keys) ───────
# Get from: https://www.binance.com/en/my/settings/api-management
# Only needed for private account data (not required for market data)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Groq AI (free tier — falls back to mock responses if not set) ─────
# Get a FREE key at: https://console.groq.com
# Model: llama-3.3-70b-versatile (fastest + smartest free model)
GROQ_API_KEY=gsk_your-groq-key-here

# ── Security ──────────────────────────────────────────────────────────
# MUST be at least 32 characters in production
JWT_SECRET=super-secret-development-key-alpha-ai-change-me-in-production

# ── Pro Mode Signal Filters (optional) ───────────────────────────────
# Enable stricter gate for higher-quality setups.
PRO_MODE_ENABLED=true
PRO_MIN_CONFIDENCE=78
PRO_MIN_RR=2.5
PRO_MAX_DISTANCE_PCT=0.012
PRO_ALLOW_RANGING_RISK=false
PRO_ALLOW_HIGH_VOLATILITY=false
PRO_ALLOW_QUALITY_C=false
